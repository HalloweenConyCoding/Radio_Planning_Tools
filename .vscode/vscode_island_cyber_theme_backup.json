        ".part.activitybar .composite-bar": {
            "background": "linear-gradient(180deg, rgba(0,229,255,0.12), rgba(255,43,214,0.08), rgba(57,255,20,0.08)) !important",
            "border-radius": "9999px",
            "overflow": "hidden !important",
            "width": "calc(100% - 4px) !important",
            "margin-left": "auto !important",
            "margin-right": "auto !important",
            "padding": "8px 3px !important",
            "box-sizing": "border-box !important",
            "display": "flex !important",
            "flex-direction": "column !important",
            "align-items": "center !important",
            "border": "1px solid rgba(0,229,255,0.28) !important",
            "box-shadow": "0 0 14px rgba(0,229,255,0.20), inset 0 0 14px rgba(255,43,214,0.08) !important"
        },
        ".part.activitybar .content > div:last-child": {
            "transform": "translateY(-10px) !important"
